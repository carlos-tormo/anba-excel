# Copy to .env and fill values

# Fallback local admin login
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password

# Session cookie/security
SESSION_TTL_SECONDS=28800
SESSION_CLEANUP_INTERVAL_SECONDS=120
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
# COOKIE_DOMAIN=example.com

# Login rate limiting
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_BLOCK_SECONDS=900

# Comma-separated emails that should have admin rights after Google sign-in
ADMIN_EMAILS=you@example.com

# Google OAuth (Web Application credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# Optional: custom environment file path
# ENV_FILE=/absolute/path/to/.env
