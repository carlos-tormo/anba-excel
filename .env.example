# Copy to .env and fill values

# Fallback local admin login
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password

# Session cookie/security
SESSION_TTL_SECONDS=28800
SESSION_CLEANUP_INTERVAL_SECONDS=120
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
# COOKIE_DOMAIN=example.com
# CSP is enforced by default. Temporarily set CSP_REPORT_ONLY=true while
# testing frontend changes that might introduce inline scripts/styles.
CSP_REPORT_ONLY=false

# Login rate limiting
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_BLOCK_SECONDS=900

# Comma-separated emails that should have admin rights after Google sign-in
ADMIN_EMAILS=you@example.com

# Optional comma-separated Google email to team mappings for GM access.
# Admins can also assign signed-up users to teams from Admin Menu > Users.
# Supported formats: gm@example.com:ATL,other-gm@example.com=BOS
# A GM can be scoped to multiple teams with / or |, e.g. gm@example.com:ATL/BKN
GM_ACCOUNTS=

# Google OAuth (Web Application credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# Discord notifications
DISCORD_NOTIFICATIONS_ENABLED=true
DISCORD_WEBHOOK_URL=
DISCORD_FREE_AGENT_OFFERS_WEBHOOK_URL=
DISCORD_FREE_AGENT_OFFERS_FORUM_TAG_IDS=
DISCORD_NOTIFY_ROLE_ID=486604867293544458
DISCORD_WEBHOOK_TIMEOUT_SECONDS=5
DISCORD_BOT_TOKEN=

# Discord waiting-list onboarding worker
# The bot application must have the privileged Server Members intent enabled.
PUBLIC_BASE_URL=https://your-league.example.com
WAITING_LIST_PUBLIC_BASE_URL=
WAITING_LIST_DISCORD_ROLE_ID=1164127012403810315
WAITING_LIST_INVITE_TTL_SECONDS=604800
DISCORD_GATEWAY_URL=wss://gateway.discord.gg
DISCORD_API_BASE_URL=https://discord.com/api/v10

# Optional Discord notification images via OpenAI.
# Leave disabled unless you want every Discord notification to attempt one image.
DISCORD_IMAGE_NOTIFICATIONS_ENABLED=false
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_FORMAT=jpeg
OPENAI_IMAGE_TIMEOUT_SECONDS=120
OPENAI_REFERENCE_IMAGE_TIMEOUT_SECONDS=20
OPENAI_REFERENCE_IMAGE_MAX_BYTES=6000000

# Optional: custom environment file path
# ENV_FILE=/absolute/path/to/.env
